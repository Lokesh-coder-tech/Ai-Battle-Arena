{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "NodeNext",

    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}